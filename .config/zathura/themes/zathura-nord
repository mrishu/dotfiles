# Zathura Nord Colorscheme (Dark)

# Notification
set notification-error-bg       "#2e3440"
set notification-error-fg       "#bf616a"
set notification-warning-bg     "#2e3440"
set notification-warning-fg     "#ebcb8b"
set notification-bg             "#2e3440"
set notification-fg             "#88c0d0"

# Completion
set completion-bg               "#3b4252"
set completion-fg               "#eceff4"
set completion-group-bg         "#2e3440"
set completion-group-fg         "#88c0d0"
set completion-highlight-bg     "#81a1c1"
set completion-highlight-fg     "#2e3440"

# Index Mode
set index-bg                    "#3b4252"
set index-fg                    "#eceff4"
set index-active-bg             "#81a1c1"
set index-active-fg             "#2e3440"

# Input Bar
set inputbar-bg                 "#2e3440"
set inputbar-fg                 "#eceff4"

# Stausbar
set statusbar-bg                "#434c5e"
set statusbar-fg                "#d8dee9"

# Highlighting
set highlight-color             "#88c0d0"
set highlight-active-color      "#a3be8c"

# Default
set default-bg                  "#2e3440"
set default-fg                  "#eceff4"
set render-loading              true
set render-loading-bg           "#2e3440"
set render-loading-fg           "#eceff4"

# Recolor book content's color
set recolor-lightcolor          "#2e3440"
set recolor-darkcolor           "#eceff4"
set recolor                     "true"
# set recolor-keephue             true
